# ===== WayTrip 后端环境配置 =====
# 将此文件复制为 .env 并填入实际值
# cp .env.example .env
# ----- 数据库配置 -----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=waytrip_db
DB_USERNAME=root
DB_PASSWORD=
# ----- Redis 配置 -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# ----- JWT 配置 -----
# 用于签名 Token 的密钥（建议至少 32 个字符）
JWT_SECRET=
# ----- 微信小程序配置 -----
# 从 https://mp.weixin.qq.com/ 获取
# 同时需要在 travel-miniapp/src/manifest.json 中更新 appid
WECHAT_APPID=
WECHAT_SECRET=
# ----- 文件上传配置 -----
UPLOAD_PATH=./uploads

# ----- 阿里云 DashScope（通义，旅游助手对话 + 本地 RAG 向量 Embedding）-----
# 从阿里云百炼/灵积控制台获取 API-Key。启动时会按顺序读取 .env 与 .env.local（后者覆盖前者），不会写回磁盘。
#
# 密钥建议放在「本机专用」的 .env.local（已在 .gitignore），避免与模板 .env 混用或被工具还原成空值：
#   复制本段到 travel-server/.env.local 并填写：
# DASHSCOPE_API_KEY=
# SPRING_AI_DASHSCOPE_API_KEY=
# AI_DASHSCOPE_API_KEY=
#
# 重要：仅写 DASHSCOPE_API_KEY 时，部分环境下 Spring 不会自动映射到 spring.ai.dashscope.api-key；
# 程序已把 DASHSCOPE_API_KEY 同步为 SPRING_AI_DASHSCOPE_API_KEY（与官方环境变量一致）。也可多行写同一值：
DASHSCOPE_API_KEY=
SPRING_AI_DASHSCOPE_API_KEY=
AI_DASHSCOPE_API_KEY=
#
# 不配置时要启动后端（不要助手）：使用 profile dev,noai